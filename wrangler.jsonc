{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "obsidian-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ALLOWED_GITHUB_USERNAME": "Aventerica89",
    "VAULT_REPO_OWNER": "Aventerica89",
    "VAULT_REPO_NAME": "Obsidian-Claude",
    "VAULT_REPO_BRANCH": "main",
    "CHATGPT_MCP_FOLDER": "_Inbox",
    "CHATGPT_MCP_SECTION": "ChatGPT MCP",
    "CHATGPT_MCP_SESSION_FOLDER_ROOT": "John Notes/App Dev",
    "CHATGPT_MCP_SESSION_GROUPS": "{\"agency-ops\":\"John Notes/App Dev/Agency Ops\",\"app-cloud-panel\":\"John Notes/App Dev/App Cloud Panel\",\"clarity\":\"John Notes/App Dev/Clarity\",\"cross-app\":\"John Notes/App Dev/Cross App\",\"flos-sports-bar\":\"John Notes/App Dev/Flos Sports Bar\",\"jb-ops\":\"John Notes/App Dev/JB Ops\",\"local-claude-manager\":\"John Notes/App Dev/Local Claude Manager\",\"obsidian-mcp\":\"John Notes/App Dev/Obsidian MCP\",\"plugins-skills-commands\":\"John Notes/App Dev/Plugins Skills Commands\",\"travel-nurse\":\"John Notes/App Dev/Travel Nurse\",\"urls-to-go\":\"John Notes/App Dev/URLs to Go\",\"vaporforge\":\"John Notes/App Dev/VaporForge\",\"vaporops\":\"John Notes/App Dev/VaporOps\",\"wp-dispatch\":\"John Notes/App Dev/WP Dispatch\"}"
  },
  "migrations": [
    {
      "new_sqlite_classes": ["ObsidianMCP"],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "ObsidianMCP",
        "name": "MCP_OBJECT"
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "832809aea5f94269985bfbd5517d24d7"
    }
  ],
  "observability": {
    "enabled": true
  },
  "dev": {
    "port": 8788
  }
}
